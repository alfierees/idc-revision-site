---
interface Props {
  title: string;
  slug: string;
  placeholder: boolean;
  index: number;
}
const { title, slug, placeholder, index } = Astro.props;
const delay = `${index * 60}ms`;
---
{placeholder ? (
  <div
    class="subject-card placeholder"
    style={`animation: rise-in 280ms ease-out both; animation-delay: ${delay};`}
  >
    <p class="font-ui text-xs uppercase tracking-[0.15em] text-ink-faint">Year 2 · Sem 2</p>
    <h2>{title}</h2>
    <p class="await">Awaiting ingestion.</p>
  </div>
) : (
  <a
    href={`/subjects/${slug}/dictionary`}
    class="subject-card"
    style={`animation: rise-in 280ms ease-out both; animation-delay: ${delay};`}
  >
    <p class="font-ui text-xs uppercase tracking-[0.15em] text-ink-faint">Year 2 · Sem 2</p>
    <h2>{title}</h2>
    <p class="open">Open <span class="arr" aria-hidden="true">→</span></p>
  </a>
)}

<style>
  .subject-card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 12.5rem;
    text-decoration: none;
    border-radius: var(--radius-card);
    background: var(--color-card);
    box-shadow: var(--shadow-soft);
    padding: 2rem 2rem 1.7rem;
    overflow: hidden;
    transition: transform 0.28s cubic-bezier(0.2, 0.7, 0.3, 1), box-shadow 0.28s ease;
  }
  .subject-card h2 {
    margin-top: 0.85rem;
    font-family: var(--font-display);
    font-size: 1.85rem;
    font-variation-settings: "opsz" 48, "wght" 500;
    color: var(--color-ink);
  }
  .subject-card .open {
    margin-top: auto;
    padding-top: 1.3rem;
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-accent);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .subject-card .open .arr { transition: transform 0.28s cubic-bezier(0.2, 0.7, 0.3, 1); }
  a.subject-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lift);
  }
  a.subject-card:hover .open .arr { transform: translateX(5px); }
  .subject-card::after {
    content: "";
    position: absolute;
    left: 0; right: 0; top: 0;
    height: 3px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.2, 0.7, 0.3, 1);
    opacity: 0.85;
  }
  a.subject-card:hover::after { transform: scaleX(1); }

  .subject-card.placeholder {
    background: color-mix(in srgb, var(--color-paper-deep) 55%, var(--color-paper));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-rule) 70%, transparent);
    cursor: default;
  }
  .subject-card.placeholder h2 {
    color: var(--color-ink-muted);
    font-variation-settings: "opsz" 48, "wght" 420;
  }
  .subject-card.placeholder .await {
    margin-top: auto;
    padding-top: 1.3rem;
    font-style: italic;
    color: var(--color-ink-faint);
    font-size: 0.95rem;
  }
  .subject-card.placeholder::after { display: none; }
</style>
