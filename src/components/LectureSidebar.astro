---
interface LectureEntry {
  slug: string;
  title: string;
  week?: number;
}
interface Section {
  id: string;       // the rehype-slug id, e.g. "cournot-1838-quantity-competition"
  text: string;     // plain heading text (fallback)
  html?: string;    // heading inner HTML — lets KaTeX render as math in the TOC
  level: number;    // 2 for h2, 3 for h3, etc.
}
interface Props {
  subject: string;
  lectures: LectureEntry[];
  currentSlug: string;
  currentSections: Section[];
}
const { subject, lectures, currentSlug, currentSections } = Astro.props;
const sorted = [...lectures].sort((a, b) => {
  if (a.week !== undefined && b.week !== undefined) return a.week - b.week;
  if (a.week !== undefined) return -1;
  if (b.week !== undefined) return 1;
  return a.title.localeCompare(b.title);
});
const current = sorted.find((l) => l.slug === currentSlug);
const others = sorted.filter((l) => l.slug !== currentSlug);
---
<aside class="rail">
  <p class="toc-label">Lectures</p>
  {current && <p class="toc-current">{current.title}</p>}
  {currentSections.length > 0 && (
    <ul class="toc-list">
      {currentSections.map((s) => (
        <li>
          {s.html ? (
            <a href={`#${s.id}`} class={s.level === 3 ? "lvl-3" : "lvl-2"} set:html={s.html} />
          ) : (
            <a href={`#${s.id}`} class={s.level === 3 ? "lvl-3" : "lvl-2"}>{s.text}</a>
          )}
        </li>
      ))}
    </ul>
  )}
  {others.length > 0 && (
    <nav class="toc-other">
      {others.map((l) => (
        <a href={`/subjects/${subject}/lectures/${l.slug}`}>{l.title}</a>
      ))}
    </nav>
  )}
</aside>
