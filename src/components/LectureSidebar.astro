---
interface LectureEntry {
  slug: string;
  title: string;
  week?: number;
}
interface Section {
  id: string;       // the rehype-slug id, e.g. "cournot-1838-quantity-competition"
  text: string;     // human heading text, e.g. "Cournot (1838) — Quantity competition"
  level: number;    // 2 for h2, 3 for h3, etc.
}
interface Props {
  subject: string;
  lectures: LectureEntry[];
  currentSlug: string;
  currentSections: Section[];
}
const { subject, lectures, currentSlug, currentSections } = Astro.props;
const sorted = [...lectures].sort((a, b) => {
  if (a.week !== undefined && b.week !== undefined) return a.week - b.week;
  if (a.week !== undefined) return -1;
  if (b.week !== undefined) return 1;
  return a.title.localeCompare(b.title);
});
---
<aside class="lecture-sidebar font-ui text-sm">
  <p class="font-ui text-xs uppercase tracking-[0.15em] text-ink-muted mb-4">Lectures</p>
  <nav>
    <ol class="space-y-1 list-none p-0">
      {sorted.map((l) => (
        <li>
          {l.slug === currentSlug ? (
            <>
              <span class="block py-1 text-ink font-medium">{l.title}</span>
              {currentSections.length > 0 && (
                <ul class="ml-3 mt-1 mb-2 space-y-0.5 list-none p-0 border-l border-rule">
                  {currentSections.map((s) => (
                    <li>
                      <a
                        href={`#${s.id}`}
                        class={`block pl-3 py-0.5 text-ink-soft hover:text-accent ${s.level === 3 ? "pl-6 text-xs" : ""}`}
                      >
                        {s.text}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </>
          ) : (
            <a
              href={`/subjects/${subject}/lectures/${l.slug}`}
              class="block py-1 text-ink-soft hover:text-accent"
            >
              {l.title}
            </a>
          )}
        </li>
      ))}
    </ol>
  </nav>
</aside>

<style>
  .lecture-sidebar {
    position: sticky;
    top: 5rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
  }
</style>
