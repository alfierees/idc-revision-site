---
// Client-side mermaid: converts <pre><code class="language-mermaid"> blocks
// (produced by the markdown renderer from ```mermaid fences) into diagrams.
// Loads mermaid from CDN only when a mermaid block is present.
---
<script>
  const blocks = Array.from(
    document.querySelectorAll<HTMLElement>("code.language-mermaid, code.language-Mermaid"),
  );
  if (blocks.length > 0) {
    const { default: mermaid } = await import(
      "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs"
    );
    mermaid.initialize({ startOnLoad: false, securityLevel: "loose", theme: "neutral" });
    blocks.forEach((code, i) => {
      const pre = code.closest("pre");
      const host = document.createElement("div");
      host.className = "mermaid";
      host.id = `mermaid-${i}`;
      host.textContent = code.textContent ?? "";
      (pre ?? code).replaceWith(host);
    });
    await mermaid.run({ querySelector: ".mermaid" });
  }
</script>
