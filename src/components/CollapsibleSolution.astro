---
interface Props { html: string; }
const { html } = Astro.props;
---
<details class="mt-4 group">
  <summary class="cursor-pointer select-none list-none font-ui text-xs uppercase tracking-[0.15em] text-accent hover:text-ink transition-colors">
    Show solution&nbsp;<span class="inline-block transition-transform group-open:rotate-90">→</span>
  </summary>
  <div class="mt-3 pt-3 border-t border-rule text-base text-ink-soft" set:html={html} />
</details>
<style>
  summary::-webkit-details-marker { display: none; }
  summary { list-style: none; }
</style>
