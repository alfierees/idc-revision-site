---
import "../styles/globals.css";
const { title = "IDC Revision" } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <header class="border-b border-rule">
      <div class="mx-auto max-w-5xl px-6 py-5 flex items-center justify-between">
        <a href="/" class="font-display text-lg text-ink" style="font-variation-settings: 'opsz' 36, 'wght' 500;">
          IDC&nbsp;Revision
        </a>
        <span class="font-ui text-xs uppercase tracking-[0.18em] text-ink-muted">Year 2 · Semester 2</span>
      </div>
    </header>
    <main class="mx-auto max-w-5xl px-6 py-12">
      <slot />
    </main>
  </body>
</html>
