---
import "../styles/globals.css";
import { getCollection } from "astro:content";
import ChatWidget from "./ChatWidget.tsx";

interface Props {
  title?: string;
  /** Subject slug — when set, the header shows the subject switcher + section tabs. */
  subject?: string;
  active?: "lectures" | "dictionary" | "recipes" | "problem-sets" | "past-papers";
  /** Show the sidebar collapse toggle (pages with a #content-grid rail). */
  hasSidebar?: boolean;
}
const { title = "IDC Revision", subject, active, hasSidebar = false } = Astro.props;

const subjects = await getCollection("subjects");
subjects.sort((a, b) => {
  if (a.data.placeholder !== b.data.placeholder) return a.data.placeholder ? 1 : -1;
  return a.data.title.localeCompare(b.data.title);
});
const current = subject ? subjects.find((s) => s.data.slug === subject) : undefined;

const tabs = [
  { id: "lectures",     label: "Lectures" },
  { id: "dictionary",   label: "Dictionary" },
  { id: "recipes",      label: "Recipes" },
  { id: "problem-sets", label: "Problem Sets" },
  { id: "past-papers",  label: "Past Papers" },
] as const;
const section = active ?? "dictionary";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <div class="read-progress" id="read-progress" aria-hidden="true"></div>
    <header class="site-header">
      <div class="bar">
        <div class="crumb">
          <a href="/" class="brand"><span class="mark">IDC</span> Revision</a>
          {current && <span class="sep" aria-hidden="true">/</span>}
          {current && (
            <div class="subject-menu" id="subject-menu">
              <button
                type="button"
                class="subject-trigger"
                aria-expanded="false"
                aria-haspopup="menu"
              >
                {current.data.title}
                <span class="chev" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
                </span>
              </button>
              <div class="subject-pop" hidden role="menu">
                <p class="subject-pop-label">Switch subject</p>
                {subjects.map((s) =>
                  s.data.placeholder ? (
                    <span class="subject-opt disabled" role="menuitem" aria-disabled="true">
                      {s.data.title}
                      <span class="so-await">Awaiting</span>
                    </span>
                  ) : (
                    <a
                      href={`/subjects/${s.data.slug}/${section}`}
                      class={`subject-opt ${s.data.slug === subject ? "current" : ""}`}
                      role="menuitem"
                    >
                      {s.data.title}
                      {s.data.slug === subject && <span class="so-tick" aria-hidden="true">●</span>}
                    </a>
                  ),
                )}
              </div>
            </div>
          )}
        </div>
        {current && (
          <nav class="header-tabs" aria-label="Subject sections">
            {tabs.map((t) => (
              <a
                href={`/subjects/${subject}/${t.id}`}
                class={active === t.id ? "active" : ""}
                aria-current={active === t.id ? "page" : undefined}
              >
                {t.label}
              </a>
            ))}
          </nav>
        )}
        <div class="bar-right">
          {hasSidebar && (
            <button id="sidebar-toggle" type="button" class="panel-toggle" aria-pressed="false" title="Toggle sidebar">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M9 4v16"/></svg>
            </button>
          )}
          {!current && <span class="header-meta">Year 2 · Sem 2</span>}
        </div>
      </div>
    </header>
    <main class="mx-auto max-w-6xl px-6 py-10">
      <slot />
    </main>

    <script>
      // ---- reading progress bar ----
      const prog = document.getElementById("read-progress");
      if (prog) {
        const onScroll = () => {
          const h = document.documentElement;
          const max = h.scrollHeight - h.clientHeight;
          prog.style.width = (max > 0 ? (window.scrollY / max) * 100 : 0) + "%";
        };
        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
      }

      // ---- subject dropdown ----
      const menu = document.getElementById("subject-menu");
      const trigger = menu?.querySelector<HTMLButtonElement>(".subject-trigger");
      const pop = menu?.querySelector<HTMLElement>(".subject-pop");
      if (menu && trigger && pop) {
        const setOpen = (open: boolean) => {
          pop.hidden = !open;
          trigger.setAttribute("aria-expanded", String(open));
        };
        trigger.addEventListener("click", () => setOpen(pop.hidden));
        document.addEventListener("mousedown", (e) => {
          if (!menu.contains(e.target as Node)) setOpen(false);
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") setOpen(false);
        });
      }

      // ---- sidebar collapse (toggle lives in the header) ----
      const KEY = "idc-sidebar-hidden";
      const grid = document.getElementById("content-grid");
      const toggleBtn = document.getElementById("sidebar-toggle");
      if (grid && toggleBtn) {
        const apply = (hidden: boolean) => {
          grid.classList.toggle("sidebar-collapsed", hidden);
          toggleBtn.classList.toggle("active", !hidden);
          toggleBtn.setAttribute("aria-pressed", String(!hidden));
          toggleBtn.setAttribute("title", hidden ? "Show sidebar" : "Hide sidebar");
        };
        apply(localStorage.getItem(KEY) === "1");
        toggleBtn.addEventListener("click", () => {
          const hidden = !grid.classList.contains("sidebar-collapsed");
          localStorage.setItem(KEY, hidden ? "1" : "0");
          apply(hidden);
        });
      }

      // ---- TOC scroll-spy ----
      const tocLinks = Array.from(
        document.querySelectorAll<HTMLAnchorElement>('.toc-list a[href^="#"]'),
      );
      if (tocLinks.length > 0) {
        const targets = tocLinks
          .map((a) => {
            const el = document.getElementById(decodeURIComponent(a.hash.slice(1)));
            return el ? { a, el } : null;
          })
          .filter((x): x is { a: HTMLAnchorElement; el: HTMLElement } => x !== null);
        const header = document.querySelector<HTMLElement>(".site-header");
        const onSpy = () => {
          const off = (header?.offsetHeight ?? 85) + 40;
          const y = window.scrollY + off;
          let cur: HTMLAnchorElement | null = null;
          for (const t of targets) {
            if (t.el.offsetTop <= y) cur = t.a;
          }
          for (const t of targets) t.a.classList.toggle("active", t.a === cur);
        };
        onSpy();
        window.addEventListener("scroll", onSpy, { passive: true });
      }
    </script>
    <ChatWidget client:idle />
    <style is:global>
      .chat-widget { position: fixed; right: 1.25rem; bottom: 1.25rem; z-index: 50; }
      .chat-fab { background: var(--color-accent, #b4532a); color: #fff; border: 0; border-radius: 999px;
        padding: 0.7rem 1.2rem; font-family: var(--font-ui, sans-serif); font-weight: 600; cursor: pointer;
        box-shadow: 0 4px 14px rgba(0,0,0,.18); }
      .chat-panel { width: min(380px, 92vw); height: min(560px, 80vh); display: flex; flex-direction: column;
        background: var(--color-paper, #fff); border: 1px solid var(--color-rule, #ddd); border-radius: 14px; overflow: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,.22); }
      .chat-head { display: flex; justify-content: space-between; align-items: center; padding: .7rem 1rem;
        border-bottom: 1px solid var(--color-rule, #eee); font-family: var(--font-ui, sans-serif); font-weight: 600; }
      .chat-head button { background: none; border: 0; font-size: 1.3rem; cursor: pointer; line-height: 1; }
      .chat-body { flex: 1; overflow-y: auto; padding: 1rem; display: flex; flex-direction: column; gap: .9rem; }
      .chat-starters { display: flex; flex-direction: column; gap: .5rem; }
      .chat-starters button { text-align: left; padding: .55rem .8rem; border: 1px solid var(--color-rule, #ddd);
        border-radius: 8px; background: transparent; cursor: pointer; font-family: var(--font-ui, sans-serif); }
      .chat-msg { font-size: .92rem; line-height: 1.5; }
      .chat-user { align-self: flex-end; background: var(--color-paper-deep, #f0ece3); padding: .5rem .8rem;
        border-radius: 10px; max-width: 85%; }
      .chat-assistant p { margin: 0 0 .6rem; }
      .chat-sources { margin-top: .6rem; font-size: .8rem; }
      .chat-sources span { font-weight: 600; color: var(--color-ink-muted, #888); }
      .chat-sources ul { margin: .3rem 0 0; padding-left: 1rem; }
      .chat-doc { margin-left: .4rem; font-size: .72rem; color: var(--color-ink-muted, #888); }
      .chat-input { display: flex; gap: .5rem; padding: .7rem; border-top: 1px solid var(--color-rule, #eee); }
      .chat-input input { flex: 1; border: 1px solid var(--color-rule, #ddd); border-radius: 8px; padding: .5rem .7rem;
        font-family: var(--font-ui, sans-serif); }
      .chat-input button { border: 0; background: var(--color-accent, #b4532a); color: #fff; border-radius: 8px;
        padding: 0 1rem; cursor: pointer; }
    </style>
  </body>
</html>
