---
// Collapse/expand the content sidebar. Targets #content-grid on the page and
// persists the preference globally in localStorage so it sticks across pages.
---
<button id="sidebar-toggle" type="button" class="sidebar-toggle" aria-pressed="false" title="Toggle sidebar">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="4" width="18" height="16" rx="2"></rect>
    <line x1="9" y1="4" x2="9" y2="20"></line>
  </svg>
  <span class="sidebar-toggle-label">Hide sidebar</span>
</button>
<script>
  const KEY = "idc-sidebar-hidden";
  const grid = document.getElementById("content-grid");
  const btn = document.getElementById("sidebar-toggle");
  const label = btn?.querySelector(".sidebar-toggle-label");
  if (grid && btn) {
    const apply = (hidden: boolean) => {
      grid.classList.toggle("sidebar-collapsed", hidden);
      btn.setAttribute("aria-pressed", String(hidden));
      if (label) label.textContent = hidden ? "Show sidebar" : "Hide sidebar";
    };
    apply(localStorage.getItem(KEY) === "1");
    btn.addEventListener("click", () => {
      const hidden = !grid.classList.contains("sidebar-collapsed");
      localStorage.setItem(KEY, hidden ? "1" : "0");
      apply(hidden);
    });
  }
</script>
