---
import Layout from "../components/Layout.astro";
import SubjectCard from "../components/SubjectCard.astro";
import { getCollection } from "astro:content";

const subjects = await getCollection("subjects");
subjects.sort((a, b) => {
  if (a.data.placeholder !== b.data.placeholder) return a.data.placeholder ? 1 : -1;
  return a.data.title.localeCompare(b.data.title);
});
---
<Layout title="IDC Revision">
  <section class="reading">
    <p class="font-ui text-xs uppercase tracking-[0.18em] text-ink-muted">For the exams</p>
    <h1 class="mt-3 font-display text-4xl" style="font-variation-settings: 'opsz' 96, 'wght' 500;">
      Revise.
    </h1>
    <p class="mt-4 text-base text-ink-soft">
      Five subjects. Pick one to open its dictionary, exam prep, problem sets and past papers.
    </p>
  </section>
  <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {subjects.map((s, i) => (
      <SubjectCard title={s.data.title} slug={s.data.slug} placeholder={s.data.placeholder} index={i} />
    ))}
  </div>
</Layout>
