---
import Layout from "../../../../components/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const subjects = await getCollection("subjects");
  return subjects.map((s) => ({ params: { subject: s.data.slug } }));
}

const subjectSlug = Astro.params.subject!;
const papers = (await getCollection("past-papers", (p) => p.data.subject === subjectSlug))
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));

const subject = (await getCollection("subjects", (s) => s.data.slug === subjectSlug))[0];
---
<Layout title={`${subject.data.title} · Past Papers`} subject={subjectSlug} active="past-papers">
  {papers.length === 0 ? (
    <p class="font-ui text-sm text-ink-muted italic">No past papers yet — content not yet ingested.</p>
  ) : (
    <ul class="mt-2 space-y-4 list-none p-0">
      {papers.map((p) => {
        const slug = p.id.split("/").pop()!;
        return (
          <li>
            <a href={`/subjects/${subjectSlug}/past-papers/${slug}`} class="list-card">
              <div class="font-display text-lg text-ink" style="font-variation-settings: 'opsz' 36, 'wght' 520;">{p.data.title}</div>
              <div class="mt-1 font-ui text-sm text-ink-muted">
                {[p.data.exam, p.data.year && p.data.year >= 2000 ? p.data.year : null].filter(Boolean).join(" · ")}
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</Layout>
