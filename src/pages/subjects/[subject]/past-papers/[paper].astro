---
import Layout from "../../../../components/Layout.astro";
import TabNav from "../../../../components/TabNav.astro";
import CollapsibleSolution from "../../../../components/CollapsibleSolution.astro";
import StatusPill from "../../../../components/StatusPill";
import PaperProgress from "../../../../components/PaperProgress";
import { getCollection, getEntry } from "astro:content";
import { renderMarkdownString } from "../../../../lib/render-markdown-string";

export async function getStaticPaths() {
  const papers = await getCollection("past-papers");
  return papers.map((p) => {
    const slug = p.id.split("/").pop()!;
    return { params: { subject: p.data.subject, paper: slug } };
  });
}

const subjectSlug = Astro.params.subject!;
const paperSlug   = Astro.params.paper!;
const paper = await getEntry("past-papers", `${subjectSlug}/${paperSlug}`);
if (!paper) throw new Error(`past paper ${subjectSlug}/${paperSlug} not found`);

const allTerms = await getCollection("terms", (t) => t.data.subject === subjectSlug);
const knownSlugs = new Set(allTerms.map((t) => t.id.split("/").pop()!));

const rendered = await Promise.all(paper.data.questions.map(async (q) => ({
  id: q.id,
  questionHtml: await renderMarkdownString(q.text, subjectSlug, knownSlugs),
  solutionHtml: await renderMarkdownString(q.solution, subjectSlug, knownSlugs),
})));
const ids = paper.data.questions.map((q) => q.id);

const subject = (await getCollection("subjects", (s) => s.data.slug === subjectSlug))[0];
---
<Layout title={`${paper.data.title} · ${subject.data.title}`}>
  <p class="font-ui text-xs uppercase tracking-[0.15em] text-ink-muted">{subject.data.title}</p>
  <h1 class="mt-2 font-display text-3xl">{subject.data.title}</h1>
  <TabNav subject={subjectSlug} active="past-papers" />

  <div class="mb-6 flex items-baseline justify-between">
    <h2 class="font-display text-2xl" style="font-variation-settings: 'opsz' 48, 'wght' 500;">{paper.data.title}</h2>
    {paper.data.source_doc && (
      <a href={paper.data.source_doc} class="font-ui text-xs uppercase tracking-[0.15em] text-ink-muted hover:text-accent underline underline-offset-4">
        Original PDF ↗
      </a>
    )}
  </div>

  <PaperProgress client:load subject={subjectSlug} refSlug={paperSlug} questionIds={ids} />

  <ol class="mt-8 space-y-6 reading list-none p-0">
    {rendered.map((q) => (
      <li id={q.id} class="scroll-mt-24 rounded border border-rule bg-card p-6">
        <div class="flex items-start justify-between gap-4">
          <span class="font-mono text-sm text-ink-soft tracking-wide">{q.id}</span>
          <StatusPill client:load subject={subjectSlug} kind="past-paper" refSlug={paperSlug} question={q.id} />
        </div>
        <div class="mt-3 text-base text-ink question-body" set:html={q.questionHtml} />
        <CollapsibleSolution html={q.solutionHtml} />
      </li>
    ))}
  </ol>
</Layout>

<style is:global>
  .question-body a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
</style>
