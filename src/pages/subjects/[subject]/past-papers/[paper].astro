---
import Layout from "../../../../components/Layout.astro";
import HoverPreview from "../../../../components/HoverPreview.astro";
import GraphMounter from "../../../../components/GraphMounter.astro";
import PaperSidebar from "../../../../components/PaperSidebar.astro";
import CollapsibleSolution from "../../../../components/CollapsibleSolution.astro";
import McQuestion from "../../../../components/McQuestion";
import StatusPill from "../../../../components/StatusPill";
import Mermaid from "../../../../components/Mermaid.astro";
import { getCollection, getEntry } from "astro:content";
import { renderMarkdownString } from "../../../../lib/render-markdown-string";
import { buildLinkMap, linkHref, resolveLink } from "../../../../lib/known-links";
import { decodeHtmlEntities } from "../../../../lib/html-entities";

export async function getStaticPaths() {
  const papers = await getCollection("past-papers", (p) => p.data.in_scope);
  return papers.map((p) => {
    const slug = p.id.split("/").pop()!;
    return { params: { subject: p.data.subject, paper: slug } };
  });
}

const subjectSlug = Astro.params.subject!;
const paperSlug = Astro.params.paper!;
const paper = await getEntry("past-papers", `${subjectSlug}/${paperSlug}`);
if (!paper) throw new Error(`past paper ${subjectSlug}/${paperSlug} not found`);

const links = await buildLinkMap(subjectSlug);

// Structured mode: when the paper declares `questions`, render per-question
// cards (question shown, worked solution behind a "Show solution" toggle). The
// markdown `body` provides the framing — split on a `<!--questions-->` sentinel
// so the Setup intro renders above the cards and the recap/related-notes below.
const structured = (paper.data.questions ?? []).length > 0;

const [introMd, outroMd] = (() => {
  const body = paper.body ?? "";
  if (!structured) return [body, ""];
  const idx = body.indexOf("<!--questions-->");
  return idx === -1 ? [body, ""] : [body.slice(0, idx), body.slice(idx + "<!--questions-->".length)];
})();

const introHtml = introMd.trim() ? await renderMarkdownString(introMd, subjectSlug, links) : "";
const outroHtml = outroMd.trim() ? await renderMarkdownString(outroMd, subjectSlug, links) : "";

const renderedQuestions = await Promise.all((paper.data.questions ?? []).map(async (q) => ({
  id: q.id,
  title: q.title,
  questionHtml: await renderMarkdownString(q.text, subjectSlug, links),
  solutionHtml: await renderMarkdownString(q.solution, subjectSlug, links),
  // Multiple-choice: pre-render each option's text + per-option explanation.
  options: q.options
    ? await Promise.all(q.options.map(async (o) => ({
        label: o.label,
        correct: o.correct,
        html: await renderMarkdownString(o.text, subjectSlug, links),
        whyHtml: o.why ? await renderMarkdownString(o.why, subjectSlug, links) : "",
      })))
    : null,
})));

// Flat-mode body (unchanged behaviour for papers without `questions`).
const flatHtml = structured ? "" : await renderMarkdownString(paper.body ?? "", subjectSlug, links);

const allPapers = (await getCollection("past-papers", (p) => p.data.subject === subjectSlug && p.data.in_scope))
  .map((p) => ({ slug: p.id.split("/").pop()!, title: p.data.title, year: p.data.year }));

// Sidebar sections: in structured mode list the questions; otherwise derive from
// the rendered headings (keep inner HTML so KaTeX in headings renders in the TOC).
let sections: { id: string; text: string; html: string; level: number }[] = [];
if (structured) {
  sections = renderedQuestions.map((q) => ({ id: q.id, text: q.title ?? q.id, html: "", level: 2 }));
} else {
  const sectionRe = /<(h2|h3)[^>]*id="([^"]+)"[^>]*>(.*?)<\/\1>/g;
  for (const m of flatHtml.matchAll(sectionRe)) {
    sections.push({ id: m[2], text: decodeHtmlEntities(m[3].replace(/<[^>]+>/g, "")).trim(), html: m[3].replace(/<\/?a\b[^>]*>/g, ""), level: m[1] === "h2" ? 2 : 3 });
  }
}

const meta = [paper.data.exam, paper.data.instructor, paper.data.status].filter(Boolean);
const subject = (await getCollection("subjects", (s) => s.data.slug === subjectSlug))[0];
---
<Layout title={`${paper.data.title} · ${subject.data.title}`} subject={subjectSlug} active="past-papers" hasSidebar>
  <div id="content-grid" class="content-grid">
    <PaperSidebar subject={subjectSlug} papers={allPapers} currentSlug={paperSlug} currentSections={sections} />
    <article class="paper-body">
      {meta.length > 0 && (
        <p class="doc-meta">{meta.join(" · ")}</p>
      )}
      <div class="flex items-baseline justify-between gap-4">
        <h1 class="doc-title">{paper.data.title}</h1>
        {paper.data.source_doc && (
          <a href={paper.data.source_doc} class="shrink-0 font-ui text-xs uppercase tracking-[0.15em] text-ink-muted hover:text-accent">
            Original paper ↗
          </a>
        )}
      </div>
      {paper.data.dataset && (
        <p class="mt-2 font-ui text-sm text-ink-muted italic">Dataset: {paper.data.dataset}</p>
      )}
      {paper.data.tags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2 list-none p-0">
          {paper.data.tags.map((tag) => {
            const target = resolveLink(links, tag);
            return target ? (
              <li><a href={linkHref(subjectSlug, target)} class="tag tag-link">#{tag}</a></li>
            ) : (
              <li><span class="tag tag-muted">#{tag}</span></li>
            );
          })}
        </ul>
      )}

      {structured ? (
        <>
          {introHtml && <div class="mt-8 paper-prose prose-card" set:html={introHtml} />}
          <ol class="mt-8 space-y-6 list-none p-0">
            {renderedQuestions.map((q) => (
              <li id={q.id} class="qcard rounded-card bg-card p-7 shadow-soft">
                <div class="flex items-start justify-between gap-4">
                  <span class="qid">{q.title ?? q.id}</span>
                  <StatusPill client:load subject={subjectSlug} kind="past-paper" refSlug={paperSlug} question={q.id} />
                </div>
                <div class="mt-3 text-base text-ink question-body prose-card" set:html={q.questionHtml} />
                {q.options ? (
                  <McQuestion
                    client:load
                    subject={subjectSlug}
                    refSlug={paperSlug}
                    questionId={q.id}
                    options={q.options}
                    workingHtml={q.solutionHtml}
                  />
                ) : (
                  <CollapsibleSolution html={q.solutionHtml} />
                )}
              </li>
            ))}
          </ol>
          {outroHtml && <div class="mt-10 paper-prose prose-card" set:html={outroHtml} />}
        </>
      ) : (
        <div class="mt-8 paper-prose prose-card" set:html={flatHtml} />
      )}
    </article>
  </div>
  <Mermaid />
  <GraphMounter />
  <HoverPreview subject={subjectSlug} />
</Layout>

<style>
  .qcard { scroll-margin-top: calc(var(--toc-top) + 1rem); }
  .qid {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: var(--color-accent);
    display: inline-flex;
    align-items: center;
  }
</style>

<style is:global>
  /* Interactive multiple-choice (McQuestion island) */
  .mc-options { list-style: none; padding: 0; margin: 1.25rem 0 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .mc-item { margin: 0; }
  .mc-opt {
    width: 100%;
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    text-align: left;
    padding: 0.8rem 1rem;
    border: 1.5px solid var(--color-rule);
    border-radius: 12px;
    background: var(--color-card);
    color: var(--color-ink);
    font: inherit;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, box-shadow 0.15s ease;
  }
  .mc-opt:disabled { cursor: default; }
  .mc-idle:hover { border-color: var(--color-accent); background: color-mix(in srgb, var(--color-accent) 5%, var(--color-card)); }
  .mc-key {
    flex: 0 0 auto;
    width: 1.7rem; height: 1.7rem;
    display: grid; place-items: center;
    border-radius: 7px;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent-ink);
    font-family: var(--font-ui);
    font-weight: 700; font-size: 0.85rem;
  }
  .mc-text { flex: 1 1 auto; min-width: 0; }
  .mc-text p { margin: 0; }
  .mc-verdict {
    flex: 0 0 auto;
    margin-left: auto;
    align-self: center;
    font-family: var(--font-ui);
    font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase;
    white-space: nowrap;
  }
  .mc-correct { border-color: var(--color-status-done); background: var(--color-status-done-bg); }
  .mc-correct .mc-key { background: var(--color-status-done); color: var(--color-card); }
  .mc-correct .mc-verdict { color: var(--color-status-done); }
  .mc-wrong { border-color: color-mix(in srgb, var(--color-status-wrong) 35%, transparent); background: var(--color-status-wrong-bg); }
  .mc-wrong .mc-key { background: color-mix(in srgb, var(--color-status-wrong) 70%, transparent); color: var(--color-card); }
  .mc-wrong .mc-verdict { color: var(--color-status-wrong); }
  .mc-picked { box-shadow: 0 0 0 2px var(--color-accent); }
  .mc-why { margin: 0.4rem 0 0 2.55rem; font-size: 0.92rem; color: var(--color-ink-soft); }
  .mc-why p { margin: 0.3rem 0; }
  /* Narrow screens: the "WRONG · YOUR ANSWER" verdict can't share the row with the
     option text (it starves the text to ~1 word per line and overlaps). Drop it to
     its own line under the text, aligned past the letter key. */
  @media (max-width: 560px) {
    .mc-opt { flex-wrap: wrap; }
    .mc-verdict { order: 3; width: 100%; margin: 0.3rem 0 0 2.55rem; align-self: flex-start; }
  }
  .mc-after { margin-top: 1.1rem; display: flex; flex-direction: column; gap: 0.85rem; align-items: flex-start; }
  .mc-working-toggle {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.74rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--color-accent);
    padding: 0.5rem 0.85rem; border-radius: 999px;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: none; cursor: pointer;
    transition: background 0.15s ease;
  }
  .mc-working-toggle:hover { background: color-mix(in srgb, var(--color-accent) 14%, transparent); }
  .mc-chev { display: inline-block; transition: transform 0.15s ease; }
  .mc-chev-open { transform: rotate(90deg); }
  .mc-working {
    align-self: stretch;
    margin-top: 0.2rem; padding-top: 1.1rem;
    border-top: 1px solid var(--color-rule);
    color: var(--color-ink-soft);
  }
  .mc-reset {
    font-family: var(--font-ui);
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
    color: var(--color-ink-muted);
    background: none; border: none; cursor: pointer; padding: 0;
  }
  .mc-reset:hover { color: var(--color-accent); }
</style>
