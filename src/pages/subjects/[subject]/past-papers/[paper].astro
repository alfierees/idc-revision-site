---
import Layout from "../../../../components/Layout.astro";
import HoverPreview from "../../../../components/HoverPreview.astro";
import PaperSidebar from "../../../../components/PaperSidebar.astro";
import CollapsibleSolution from "../../../../components/CollapsibleSolution.astro";
import StatusPill from "../../../../components/StatusPill";
import Mermaid from "../../../../components/Mermaid.astro";
import { getCollection, getEntry } from "astro:content";
import { renderMarkdownString } from "../../../../lib/render-markdown-string";
import { buildLinkMap, linkHref, resolveLink } from "../../../../lib/known-links";
import { decodeHtmlEntities } from "../../../../lib/html-entities";

export async function getStaticPaths() {
  const papers = await getCollection("past-papers", (p) => p.data.in_scope);
  return papers.map((p) => {
    const slug = p.id.split("/").pop()!;
    return { params: { subject: p.data.subject, paper: slug } };
  });
}

const subjectSlug = Astro.params.subject!;
const paperSlug = Astro.params.paper!;
const paper = await getEntry("past-papers", `${subjectSlug}/${paperSlug}`);
if (!paper) throw new Error(`past paper ${subjectSlug}/${paperSlug} not found`);

const links = await buildLinkMap(subjectSlug);

// Structured mode: when the paper declares `questions`, render per-question
// cards (question shown, worked solution behind a "Show solution" toggle). The
// markdown `body` provides the framing — split on a `<!--questions-->` sentinel
// so the Setup intro renders above the cards and the recap/related-notes below.
const structured = (paper.data.questions ?? []).length > 0;

const [introMd, outroMd] = (() => {
  const body = paper.body ?? "";
  if (!structured) return [body, ""];
  const idx = body.indexOf("<!--questions-->");
  return idx === -1 ? [body, ""] : [body.slice(0, idx), body.slice(idx + "<!--questions-->".length)];
})();

const introHtml = introMd.trim() ? await renderMarkdownString(introMd, subjectSlug, links) : "";
const outroHtml = outroMd.trim() ? await renderMarkdownString(outroMd, subjectSlug, links) : "";

const renderedQuestions = await Promise.all((paper.data.questions ?? []).map(async (q) => ({
  id: q.id,
  title: q.title,
  questionHtml: await renderMarkdownString(q.text, subjectSlug, links),
  solutionHtml: await renderMarkdownString(q.solution, subjectSlug, links),
})));

// Flat-mode body (unchanged behaviour for papers without `questions`).
const flatHtml = structured ? "" : await renderMarkdownString(paper.body ?? "", subjectSlug, links);

const allPapers = (await getCollection("past-papers", (p) => p.data.subject === subjectSlug && p.data.in_scope))
  .map((p) => ({ slug: p.id.split("/").pop()!, title: p.data.title, year: p.data.year }));

// Sidebar sections: in structured mode list the questions; otherwise derive from
// the rendered headings (keep inner HTML so KaTeX in headings renders in the TOC).
let sections: { id: string; text: string; html: string; level: number }[] = [];
if (structured) {
  sections = renderedQuestions.map((q) => ({ id: q.id, text: q.title ?? q.id, html: "", level: 2 }));
} else {
  const sectionRe = /<(h2|h3)[^>]*id="([^"]+)"[^>]*>(.*?)<\/\1>/g;
  for (const m of flatHtml.matchAll(sectionRe)) {
    sections.push({ id: m[2], text: decodeHtmlEntities(m[3].replace(/<[^>]+>/g, "")).trim(), html: m[3], level: m[1] === "h2" ? 2 : 3 });
  }
}

const meta = [paper.data.exam, paper.data.instructor, paper.data.status].filter(Boolean);
const subject = (await getCollection("subjects", (s) => s.data.slug === subjectSlug))[0];
---
<Layout title={`${paper.data.title} · ${subject.data.title}`} subject={subjectSlug} active="past-papers" hasSidebar>
  <div id="content-grid" class="content-grid">
    <PaperSidebar subject={subjectSlug} papers={allPapers} currentSlug={paperSlug} currentSections={sections} />
    <article class="paper-body">
      {meta.length > 0 && (
        <p class="doc-meta">{meta.join(" · ")}</p>
      )}
      <div class="flex items-baseline justify-between gap-4">
        <h1 class="doc-title">{paper.data.title}</h1>
        {paper.data.source_doc && (
          <a href={paper.data.source_doc} class="shrink-0 font-ui text-xs uppercase tracking-[0.15em] text-ink-muted hover:text-accent">
            Original paper ↗
          </a>
        )}
      </div>
      {paper.data.dataset && (
        <p class="mt-2 font-ui text-sm text-ink-muted italic">Dataset: {paper.data.dataset}</p>
      )}
      {paper.data.tags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2 list-none p-0">
          {paper.data.tags.map((tag) => {
            const target = resolveLink(links, tag);
            return target ? (
              <li><a href={linkHref(subjectSlug, target)} class="tag tag-link">#{tag}</a></li>
            ) : (
              <li><span class="tag tag-muted">#{tag}</span></li>
            );
          })}
        </ul>
      )}

      {structured ? (
        <>
          {introHtml && <div class="mt-8 paper-prose prose-card" set:html={introHtml} />}
          <ol class="mt-8 space-y-6 list-none p-0">
            {renderedQuestions.map((q) => (
              <li id={q.id} class="qcard rounded-card bg-card p-7 shadow-soft">
                <div class="flex items-start justify-between gap-4">
                  <span class="qid">{q.title ?? q.id}</span>
                  <StatusPill client:load subject={subjectSlug} kind="past-paper" refSlug={paperSlug} question={q.id} />
                </div>
                <div class="mt-3 text-base text-ink question-body prose-card" set:html={q.questionHtml} />
                <CollapsibleSolution html={q.solutionHtml} />
              </li>
            ))}
          </ol>
          {outroHtml && <div class="mt-10 paper-prose prose-card" set:html={outroHtml} />}
        </>
      ) : (
        <div class="mt-8 paper-prose prose-card" set:html={flatHtml} />
      )}
    </article>
  </div>
  <Mermaid />
  <HoverPreview subject={subjectSlug} />
</Layout>

<style>
  .qcard { scroll-margin-top: calc(var(--toc-top) + 1rem); }
  .qid {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: var(--color-accent);
    display: inline-flex;
    align-items: center;
  }
</style>
