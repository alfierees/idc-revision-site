---
import Layout from "../../../../components/Layout.astro";
import TabNav from "../../../../components/TabNav.astro";
import PaperSidebar from "../../../../components/PaperSidebar.astro";
import { getCollection, getEntry } from "astro:content";
import { renderMarkdownString } from "../../../../lib/render-markdown-string";
import { buildLinkMap, linkHref, resolveLink } from "../../../../lib/known-links";
import { decodeHtmlEntities } from "../../../../lib/html-entities";

export async function getStaticPaths() {
  const papers = await getCollection("past-papers", (p) => p.data.in_scope);
  return papers.map((p) => {
    const slug = p.id.split("/").pop()!;
    return { params: { subject: p.data.subject, paper: slug } };
  });
}

const subjectSlug = Astro.params.subject!;
const paperSlug = Astro.params.paper!;
const paper = await getEntry("past-papers", `${subjectSlug}/${paperSlug}`);
if (!paper) throw new Error(`past paper ${subjectSlug}/${paperSlug} not found`);

const links = await buildLinkMap(subjectSlug);
const html = await renderMarkdownString(paper.body ?? "", subjectSlug, links);

const allPapers = (await getCollection("past-papers", (p) => p.data.subject === subjectSlug && p.data.in_scope))
  .map((p) => ({ slug: p.id.split("/").pop()!, title: p.data.title, year: p.data.year }));

const sectionRe = /<(h2|h3)[^>]*id="([^"]+)"[^>]*>(.*?)<\/\1>/g;
const sections: { id: string; text: string; level: number }[] = [];
let m: RegExpExecArray | null;
while ((m = sectionRe.exec(html)) !== null) {
  sections.push({ id: m[2], text: decodeHtmlEntities(m[3].replace(/<[^>]+>/g, "")).trim(), level: m[1] === "h2" ? 2 : 3 });
}

const meta = [paper.data.exam, paper.data.instructor, paper.data.status].filter(Boolean);
const subject = (await getCollection("subjects", (s) => s.data.slug === subjectSlug))[0];
---
<Layout title={`${paper.data.title} · ${subject.data.title}`}>
  <p class="font-ui text-xs uppercase tracking-[0.15em] text-ink-muted">{subject.data.title}</p>
  <h1 class="mt-2 font-display text-3xl">{subject.data.title}</h1>
  <TabNav subject={subjectSlug} active="past-papers" />

  <div class="paper-grid mt-6">
    <PaperSidebar subject={subjectSlug} papers={allPapers} currentSlug={paperSlug} currentSections={sections} />
    <article class="paper-body">
      <h2 class="font-display text-2xl text-ink" style="font-variation-settings: 'opsz' 48, 'wght' 500;">{paper.data.title}</h2>
      {meta.length > 0 && (
        <p class="mt-1 font-ui text-xs uppercase tracking-[0.15em] text-ink-muted">{meta.join(" · ")}</p>
      )}
      {paper.data.dataset && (
        <p class="mt-2 font-ui text-sm text-ink-muted italic">Dataset: {paper.data.dataset}</p>
      )}
      {paper.data.tags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2 list-none p-0">
          {paper.data.tags.map((tag) => {
            const target = resolveLink(links, tag);
            return target ? (
              <li><a href={linkHref(subjectSlug, target)} class="tag tag-link">#{tag}</a></li>
            ) : (
              <li><span class="tag tag-muted">#{tag}</span></li>
            );
          })}
        </ul>
      )}
      <div class="mt-8 paper-prose prose-card" set:html={html} />
    </article>
  </div>
</Layout>

<style>
  .paper-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .paper-grid { grid-template-columns: 260px 1fr; } }
  .paper-prose :global(h2) { margin-top: 2.5rem; margin-bottom: 1rem; font-family: var(--font-display); font-size: 1.5rem; font-variation-settings: "opsz" 48, "wght" 500; color: var(--color-ink); scroll-margin-top: 5rem; }
  .paper-prose :global(h3) { margin-top: 1.75rem; margin-bottom: 0.5rem; font-family: var(--font-display); font-size: 1.2rem; font-variation-settings: "opsz" 36, "wght" 500; color: var(--color-ink); scroll-margin-top: 5rem; }
  .paper-prose :global(p) { margin-top: 1rem; }
  .paper-prose :global(a) { color: var(--color-accent); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
  .paper-prose :global(table) { display: block; overflow-x: auto; max-width: 100%; }
  .paper-prose :global(pre) { overflow-x: auto; max-width: 100%; }
</style>
