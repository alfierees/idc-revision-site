---
import Layout from "../../../../components/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const subjects = await getCollection("subjects");
  return subjects.map((s) => ({ params: { subject: s.data.slug } }));
}

const subjectSlug = Astro.params.subject!;

const docs = (await getCollection("exam-prep", (e) => e.data.subject === subjectSlug && e.data.in_scope))
  .sort((a, b) => {
    const ao = a.data.order ?? Number.POSITIVE_INFINITY;
    const bo = b.data.order ?? Number.POSITIVE_INFINITY;
    if (ao !== bo) return ao - bo;
    return a.data.title.localeCompare(b.data.title);
  });

// Method recipes live on under this section (the old "Recipes" tab folded into
// Exam Prep). They keep their own /recipes/<slug> routes — backlinks and the
// problem-set Toolkit still resolve — but are browsable here.
const recipes = (await getCollection("recipes", (r) => r.data.subject === subjectSlug && r.data.in_scope))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const subject = (await getCollection("subjects", (s) => s.data.slug === subjectSlug))[0];
---
<Layout title={`${subject.data.title} · Exam Prep`} subject={subjectSlug} active="exam-prep">
  {docs.length === 0 && recipes.length === 0 ? (
    <p class="font-ui text-sm text-ink-muted italic">No exam prep yet — content not yet ingested.</p>
  ) : (
    <div class="mt-2 space-y-10">
      {docs.length > 0 && (
        <ul class="space-y-4 list-none p-0">
          {docs.map((d) => {
            const slug = d.id.split("/").pop()!;
            return (
              <li>
                <a href={`/subjects/${subjectSlug}/exam-prep/${slug}`} class="list-card group">
                  <div class="font-display text-lg text-ink" style="font-variation-settings: 'opsz' 36, 'wght' 520;">{d.data.title}</div>
                  {d.data.description && (
                    <div class="mt-1 font-ui text-sm text-ink-muted">{d.data.description}</div>
                  )}
                  <div class="mt-1 font-ui text-sm text-ink-soft group-hover:text-accent transition-colors">Open →</div>
                </a>
              </li>
            );
          })}
        </ul>
      )}
      {recipes.length > 0 && (
        <section>
          <h2 class="font-display text-sm uppercase tracking-wide text-ink-soft" style="font-variation-settings: 'opsz' 18, 'wght' 560;">Method recipes</h2>
          <ul class="mt-3 space-y-4 list-none p-0">
            {recipes.map((r) => {
              const slug = r.id.split("/").pop()!;
              return (
                <li>
                  <a href={`/subjects/${subjectSlug}/recipes/${slug}`} class="list-card group">
                    <div class="font-display text-lg text-ink" style="font-variation-settings: 'opsz' 36, 'wght' 520;">{r.data.title}</div>
                    <div class="mt-1 font-ui text-sm text-ink-soft group-hover:text-accent transition-colors">Open →</div>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      )}
    </div>
  )}
</Layout>
