---
import Layout from "../../../../components/Layout.astro";
import HoverPreview from "../../../../components/HoverPreview.astro";
import GraphMounter from "../../../../components/GraphMounter.astro";
import LectureSidebar from "../../../../components/LectureSidebar.astro";
import Mermaid from "../../../../components/Mermaid.astro";
import { getCollection, getEntry } from "astro:content";
import { renderMarkdownString } from "../../../../lib/render-markdown-string";
import { buildLinkMap, linkHref, resolveLink } from "../../../../lib/known-links";
import { decodeHtmlEntities } from "../../../../lib/html-entities";

export async function getStaticPaths() {
  const lectures = await getCollection("lectures", (l) => l.data.in_scope);
  return lectures.map((l) => {
    const slug = l.id.split("/").pop()!;
    return { params: { subject: l.data.subject, lecture: slug } };
  });
}

const subjectSlug = Astro.params.subject!;
const lectureSlug = Astro.params.lecture!;
const lecture = await getEntry("lectures", `${subjectSlug}/${lectureSlug}`);
if (!lecture) throw new Error(`lecture ${subjectSlug}/${lectureSlug} not found`);

const links = await buildLinkMap(subjectSlug);
const html = await renderMarkdownString(lecture.body ?? "", subjectSlug, links);

const allLectures = (await getCollection("lectures", (l) => l.data.subject === subjectSlug))
  .map((l) => ({
    slug: l.id.split("/").pop()!,
    title: l.data.title,
    week: l.data.week,
  }));

// Extract section headings from the rendered HTML for the sidebar. Keep the
// inner HTML so KaTeX in headings renders as real math in the TOC.
const sectionRe = /<(h2|h3)[^>]*id="([^"]+)"[^>]*>(.*?)<\/\1>/g;
const sections: { id: string; text: string; html: string; level: number }[] = [];
let m: RegExpExecArray | null;
while ((m = sectionRe.exec(html)) !== null) {
  sections.push({
    id: m[2],
    text: decodeHtmlEntities(m[3].replace(/<[^>]+>/g, "")).trim(),
    html: m[3],
    level: m[1] === "h2" ? 2 : 3,
  });
}

const subject = (await getCollection("subjects", (s) => s.data.slug === subjectSlug))[0];
---
<Layout title={`${lecture.data.title} · ${subject.data.title}`} subject={subjectSlug} active="lectures" hasSidebar>
  <div id="content-grid" class="content-grid">
    <LectureSidebar
      subject={subjectSlug}
      lectures={allLectures}
      currentSlug={lectureSlug}
      currentSections={sections}
    />
    <article class="lecture-body">
      {(lecture.data.week !== undefined || lecture.data.instructor) && (
        <p class="doc-meta">
          {lecture.data.week !== undefined && <span>Week {lecture.data.week}</span>}
          {lecture.data.week !== undefined && lecture.data.instructor && <span> · </span>}
          {lecture.data.instructor && <span>{lecture.data.instructor}</span>}
        </p>
      )}
      <h1 class="doc-title">{lecture.data.title}</h1>
      {lecture.data.tags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2 list-none p-0">
          {lecture.data.tags.map((tag) => {
            const target = resolveLink(links, tag);
            return target ? (
              <li><a href={linkHref(subjectSlug, target)} class="tag tag-link">#{tag}</a></li>
            ) : (
              <li><span class="tag tag-muted">#{tag}</span></li>
            );
          })}
        </ul>
      )}
      <div class="mt-8 lecture-prose prose-card" set:html={html} />
    </article>
  </div>
  <Mermaid />
  <GraphMounter />
  <HoverPreview subject={subjectSlug} />
</Layout>

