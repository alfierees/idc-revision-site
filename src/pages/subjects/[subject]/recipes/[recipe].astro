---
import Layout from "../../../../components/Layout.astro";
import HoverPreview from "../../../../components/HoverPreview.astro";
import GraphMounter from "../../../../components/GraphMounter.astro";
import { getCollection, getEntry } from "astro:content";
import { renderMarkdownString } from "../../../../lib/render-markdown-string";
import { buildLinkMap } from "../../../../lib/known-links";

export async function getStaticPaths() {
  const recipes = await getCollection("recipes", (r) => r.data.in_scope);
  return recipes.map((r) => {
    const slug = r.id.split("/").pop()!;
    return { params: { subject: r.data.subject, recipe: slug } };
  });
}

const subjectSlug = Astro.params.subject!;
const recipeSlug  = Astro.params.recipe!;
const entry = await getEntry("recipes", `${subjectSlug}/${recipeSlug}`);
if (!entry) throw new Error(`recipe ${subjectSlug}/${recipeSlug} not found`);

// Full subject link map so cross-kind wiki-links and aliases in recipe bodies
// resolve (not just term→term links).
const links = await buildLinkMap(subjectSlug);

const html = await renderMarkdownString(entry.body ?? "", subjectSlug, links);

const subject = (await getCollection("subjects", (s) => s.data.slug === subjectSlug))[0];
---
<Layout title={`${entry.data.title} · ${subject.data.title}`} subject={subjectSlug} active="recipes">
  <article>
    <p class="doc-meta">Recipe</p>
    <h1 class="doc-title">{entry.data.title}</h1>
    <div class="recipe-body mt-6 text-base text-ink" set:html={html} />
  </article>
  <GraphMounter />
  <HoverPreview subject={subjectSlug} />
</Layout>

<style is:global>
  /* Marginalia numerals on recipe step lists */
  .recipe-body ol {
    list-style: none;
    counter-reset: step;
    padding-left: 0;
  }
  .recipe-body ol > li {
    counter-increment: step;
    position: relative;
    padding-left: 3.5rem;
    margin-top: 1.25rem;
  }
  .recipe-body ol > li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: -0.1em;
    font-family: var(--font-display);
    font-variation-settings: "opsz" 72, "wght" 400;
    font-size: 1.875rem;
    line-height: 1;
    color: var(--color-accent);
  }
  /* "Common pitfalls" and similar h2s inside the recipe body become marginalia rules */
  .recipe-body h2 {
    margin-top: 2.5rem;
    padding-left: 1rem;
    border-left: 2px solid var(--color-rule-strong);
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .recipe-body h2 + ul,
  .recipe-body h2 + p {
    margin-left: 1rem;
    border-left: 2px solid var(--color-rule);
    padding-left: 1rem;
    color: var(--color-ink-soft);
  }
  .recipe-body a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
</style>
