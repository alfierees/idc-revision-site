---
import Layout from "../../../../components/Layout.astro";
import TabNav from "../../../../components/TabNav.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const subjects = await getCollection("subjects");
  return subjects.map((s) => ({ params: { subject: s.data.slug } }));
}

const subjectSlug = Astro.params.subject!;
const recipes = (await getCollection("recipes", (r) => r.data.subject === subjectSlug && r.data.in_scope))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const subject = (await getCollection("subjects", (s) => s.data.slug === subjectSlug))[0];
---
<Layout title={`${subject.data.title} · Recipes`}>
  <p class="font-ui text-xs uppercase tracking-[0.15em] text-ink-muted">{subject.data.title}</p>
  <h1 class="mt-2 font-display text-3xl">{subject.data.title}</h1>
  <TabNav subject={subjectSlug} active="recipes" />
  {recipes.length === 0 ? (
    <p class="font-ui text-sm text-ink-muted italic">No recipes yet — content not yet ingested.</p>
  ) : (
    <ul class="space-y-3 reading">
      {recipes.map((r) => {
        const slug = r.id.split("/").pop()!;
        return (
          <li>
            <a href={`/subjects/${subjectSlug}/recipes/${slug}`} class="group block rounded border border-rule bg-card p-5 transition-shadow hover:shadow-sm">
              <div class="font-display text-lg text-ink" style="font-variation-settings: 'opsz' 36, 'wght' 500;">{r.data.title}</div>
              <div class="mt-1 font-ui text-sm text-ink-soft group-hover:text-accent transition-colors">Open →</div>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</Layout>
