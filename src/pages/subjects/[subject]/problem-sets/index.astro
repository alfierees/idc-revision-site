---
import Layout from "../../../../components/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const subjects = await getCollection("subjects");
  return subjects.map((s) => ({ params: { subject: s.data.slug } }));
}

const subjectSlug = Astro.params.subject!;
const sets = (await getCollection("problem-sets", (p) => p.data.subject === subjectSlug))
  .sort((a, b) => a.data.title.localeCompare(b.data.title, undefined, { numeric: true }));

const subject = (await getCollection("subjects", (s) => s.data.slug === subjectSlug))[0];
---
<Layout title={`${subject.data.title} · Problem Sets`} subject={subjectSlug} active="problem-sets">
  {sets.length === 0 ? (
    <p class="font-ui text-sm text-ink-muted italic">No problem sets yet — content not yet ingested.</p>
  ) : (
    <ul class="mt-2 space-y-4 list-none p-0">
      {sets.map((p) => {
        const slug = p.id.split("/").pop()!;
        return (
          <li>
            <a href={`/subjects/${subjectSlug}/problem-sets/${slug}`} class="list-card">
              <div class="font-display text-lg text-ink" style="font-variation-settings: 'opsz' 36, 'wght' 520;">{p.data.title}</div>
              <div class="mt-1 font-ui text-sm text-ink-muted">{p.data.questions.length} questions</div>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</Layout>
