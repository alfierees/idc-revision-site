---
import Layout from "../../../../components/Layout.astro";
import HoverPreview from "../../../../components/HoverPreview.astro";
import DictionarySearch from "../../../../components/DictionarySearch";
import { getCollection, getEntry } from "astro:content";
import { parseGlossary } from "../../../../lib/glossary";
import { renderMarkdownString } from "../../../../lib/render-markdown-string";
import { buildLinkMap } from "../../../../lib/known-links";

export async function getStaticPaths() {
  const subjects = await getCollection("subjects");
  return subjects.map((s) => ({ params: { subject: s.data.slug } }));
}

const subjectSlug = Astro.params.subject!;
const subject = (await getCollection("subjects", (s) => s.data.slug === subjectSlug))[0];

// Prefer the glossary topic-grouped overview; fall back to the flat list when no
// glossary exists for this subject (keeps other subjects working).
const glossaryEntry = await getEntry("glossary", subjectSlug);
let topics: { title: string; slug: string; rows: { term: string; href: string; defHtml: string }[] }[] = [];
if (glossaryEntry) {
  const links = await buildLinkMap(subjectSlug);
  const g = parseGlossary(glossaryEntry.body ?? "");
  topics = await Promise.all(
    g.topics.map(async (t) => ({
      title: t.title,
      slug: t.slug,
      rows: await Promise.all(
        t.entries.map(async (e) => ({
          term: e.term,
          href: `/subjects/${subjectSlug}/dictionary/${e.slug}`,
          defHtml: await renderMarkdownString(
            e.definition + (e.lectureRef ? ` ${e.lectureRef}` : ""),
            subjectSlug, links,
          ),
        })),
      ),
    })),
  );
}

// Fallback flat list
const allTerms = await getCollection("terms", (t) => t.data.subject === subjectSlug && t.data.in_scope);
allTerms.sort((a, b) => a.data.title.localeCompare(b.data.title));
const flatEntries = allTerms.map((t) => {
  const slug = t.id.split("/").pop()!;
  return { slug, title: t.data.title, aliases: t.data.aliases, href: `/subjects/${subjectSlug}/dictionary/${slug}` };
});
---
<Layout title={`${subject.data.title} · Dictionary`} subject={subjectSlug} active="dictionary">
  {topics.length > 0 ? (
    <div class="mt-2">
      <input
        id="concept-filter"
        type="search"
        placeholder="Filter concepts…"
        class="dict-filter"
        autocomplete="off"
      />
      <div class="mt-6">
        {topics.map((t) => (
          <section class="concept-topic dict-topic" data-topic id={t.slug}>
            <h2>
              {t.title}
              <span class="count">{t.rows.length}</span>
            </h2>
            <ul class="dict-list">
              {t.rows.map((r) => (
                <li class="concept-row dict-row" data-term={r.term.toLowerCase()}>
                  <a href={r.href} class="dict-term">{r.term}</a><span class="dict-colon">:</span>
                  <span class="concept-def dict-def" set:html={r.defHtml} />
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </div>
  ) : flatEntries.length === 0 ? (
    <p class="font-ui text-sm text-ink-muted italic">Content not yet ingested.</p>
  ) : (
    <div class="grid grid-cols-1 lg:grid-cols-[240px_1fr] gap-10">
      <aside><DictionarySearch client:load terms={flatEntries} /></aside>
      <section class="reading text-ink-soft">
        <p class="font-ui text-xs uppercase tracking-[0.15em] text-ink-muted">Select a term</p>
        <p class="mt-3">Pick a term from the list to see its definition and where it appears.</p>
      </section>
    </div>
  )}
  <HoverPreview subject={subjectSlug} />
</Layout>

<style is:global>
  .concept-def { display: inline; }
  .concept-def p { display: inline; margin: 0; }
  .concept-row { line-height: 1.6; }

  .dict-filter {
    width: 100%;
    max-width: 30rem;
    font-family: var(--font-ui);
    font-size: 0.95rem;
    padding: 0.85rem 1.1rem 0.85rem 2.6rem;
    border-radius: 999px;
    background-color: var(--color-card);
    border: 1px solid color-mix(in srgb, var(--color-rule-strong) 80%, transparent);
    color: var(--color-ink);
    box-shadow: var(--shadow-soft);
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' fill='none' stroke='%238a8275' stroke-width='2' stroke-linecap='round'><circle cx='8' cy='8' r='6'/><path d='M16 16l-3.5-3.5'/></svg>");
    background-repeat: no-repeat;
    background-position: 0.95rem center;
  }
  .dict-filter:focus { outline: none; border-color: var(--color-accent); }
  .dict-filter::placeholder { color: var(--color-ink-faint); }

  .dict-topic { margin-top: 2.6rem; }
  .dict-topic > h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-variation-settings: "opsz" 40, "wght" 520;
    color: var(--color-ink);
    padding-bottom: 0.6rem;
    margin-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-rule);
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
  }
  .dict-topic > h2 .count {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-ink-faint);
  }
  .dict-list { list-style: none; margin: 0; padding: 0; }
  .dict-row {
    padding: 0.85rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-rule) 55%, transparent);
  }
  .dict-row:last-child { border-bottom: none; }
  .dict-term {
    font-family: var(--font-ui);
    font-size: 0.95rem;
    font-weight: 650;
    color: var(--color-accent-ink);
    text-decoration: none;
  }
  .dict-term:hover { color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }
  .dict-colon { color: var(--color-ink-muted); margin-right: 0.45rem; }
  .dict-def { color: var(--color-ink-soft); font-size: 0.98rem; }
  .dict-def a {
    color: var(--color-accent-ink);
    text-decoration: none;
    background-image: linear-gradient(var(--color-accent-soft), var(--color-accent-soft));
    background-size: 100% 0.14em;
    background-repeat: no-repeat;
    background-position: 0 88%;
    transition: background-size 0.18s ease, color 0.18s ease;
  }
  .dict-def a:hover { color: var(--color-accent); background-size: 100% 100%; }
  /* lecture references become small terracotta chips */
  .dict-def a[href*="/lectures/"] {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-accent);
    white-space: nowrap;
    padding: 0.1rem 0.45rem;
    border-radius: 6px;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent) !important;
    background-image: none !important;
    margin-left: 0.25rem;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .dict-def a[href*="/lectures/"]:hover { background: var(--color-accent) !important; color: #fff; }
</style>

<script>
  const input = document.getElementById("concept-filter") as HTMLInputElement | null;
  if (input) {
    input.addEventListener("input", () => {
      const q = input.value.trim().toLowerCase();
      document.querySelectorAll<HTMLElement>("[data-topic]").forEach((topic) => {
        let any = false;
        topic.querySelectorAll<HTMLElement>(".concept-row").forEach((row) => {
          const hay = (row.dataset.term ?? "") + " " + (row.textContent ?? "").toLowerCase();
          const show = q === "" || hay.includes(q);
          row.style.display = show ? "" : "none";
          if (show) any = true;
        });
        topic.style.display = any ? "" : "none";
      });
    });
  }
</script>
